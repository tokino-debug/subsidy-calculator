<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>見守りカメラ補助金 自動算出シート</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700;900&family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
<style>
:root{--bg:#0a0f1e;--surface:#111827;--surface2:#1a2235;--border:#1e3a5f;--accent:#00d4ff;--accent2:#0066ff;--accent3:#00ff88;--warn:#ffc107;--danger:#ff5252;--text:#e8f4fd;--text-muted:#6b8cae;--care:#ff6b35;--medical:#00d4ff;--glow:0 0 20px rgba(0,212,255,0.3);}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--text);font-family:'Noto Sans JP',sans-serif;min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background:radial-gradient(ellipse at 20% 20%,rgba(0,100,255,.08) 0%,transparent 50%),radial-gradient(ellipse at 80% 80%,rgba(0,212,255,.05) 0%,transparent 50%);pointer-events:none;z-index:0;}
.container{max-width:880px;margin:0 auto;padding:40px 24px 80px;position:relative;z-index:1;}
header{text-align:center;margin-bottom:48px;}
.badge{display:inline-block;background:linear-gradient(135deg,rgba(0,212,255,.15),rgba(0,100,255,.15));border:1px solid rgba(0,212,255,.3);color:var(--accent);font-size:11px;letter-spacing:3px;padding:6px 16px;border-radius:20px;margin-bottom:16px;font-family:'Inter',sans-serif;font-weight:600;}
h1{font-size:clamp(26px,5vw,38px);font-weight:900;line-height:1.2;background:linear-gradient(135deg,#fff 0%,var(--accent) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:12px;}
.subtitle{color:var(--text-muted);font-size:14px;font-weight:300;}
.step-card{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:32px;margin-bottom:20px;transition:border-color .3s;}
.step-card.active{border-color:rgba(0,212,255,.4);box-shadow:0 0 30px rgba(0,212,255,.08);}
.step-header{display:flex;align-items:center;gap:12px;margin-bottom:24px;}
.step-num{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--accent2),var(--accent));display:flex;align-items:center;justify-content:center;font-family:'Inter',sans-serif;font-weight:800;font-size:14px;color:#fff;flex-shrink:0;}
.step-label{font-size:16px;font-weight:700;}
.genre-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.genre-btn{border:2px solid var(--border);background:var(--surface2);border-radius:14px;padding:24px 20px;cursor:pointer;transition:all .25s;text-align:center;position:relative;overflow:hidden;}
.genre-btn::before{content:'';position:absolute;inset:0;opacity:0;transition:opacity .25s;}
.genre-btn.care::before{background:radial-gradient(circle at center,rgba(255,107,53,.12),transparent 70%);}
.genre-btn.medical::before{background:radial-gradient(circle at center,rgba(0,212,255,.12),transparent 70%);}
.genre-btn:hover{transform:translateY(-2px);}
.genre-btn:hover::before{opacity:1;}
.genre-btn.selected.care{border-color:var(--care);box-shadow:0 0 24px rgba(255,107,53,.25);}
.genre-btn.selected.care::before,.genre-btn.selected.medical::before{opacity:1;}
.genre-btn.selected.medical{border-color:var(--medical);box-shadow:0 0 24px rgba(0,212,255,.25);}
.genre-icon{font-size:40px;margin-bottom:12px;display:block;}
.genre-name{font-size:18px;font-weight:700;margin-bottom:6px;}
.genre-desc{font-size:12px;color:var(--text-muted);line-height:1.6;}
.genre-btn.selected.care .genre-name{color:var(--care);}
.genre-btn.selected.medical .genre-name{color:var(--medical);}
.pref-search{position:relative;margin-bottom:16px;}
.pref-search input{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:14px 16px 14px 44px;color:var(--text);font-family:'Noto Sans JP',sans-serif;font-size:15px;outline:none;transition:border-color .2s;}
.pref-search input:focus{border-color:var(--accent);}
.pref-search input::placeholder{color:var(--text-muted);}
.search-icon{position:absolute;left:14px;top:50%;transform:translateY(-50%);color:var(--text-muted);font-size:16px;}
.region-group{margin-bottom:20px;}
.region-label{font-size:11px;letter-spacing:2px;color:var(--text-muted);font-family:'Inter',sans-serif;font-weight:600;margin-bottom:10px;padding-left:4px;}
.pref-grid{display:flex;flex-wrap:wrap;gap:8px;}
.pref-tag{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:8px 14px;font-size:13px;cursor:pointer;transition:all .2s;color:var(--text-muted);font-weight:500;}
.pref-tag:hover{border-color:var(--accent);color:var(--text);}
.pref-tag.selected{background:linear-gradient(135deg,rgba(0,212,255,.15),rgba(0,100,255,.15));border-color:var(--accent);color:var(--accent);font-weight:700;}
.pref-tag.hidden{display:none;}
.input-group{margin-bottom:20px;}
.input-label{font-size:13px;color:var(--text-muted);margin-bottom:8px;display:flex;align-items:center;gap:6px;}
.input-label .unit{font-size:11px;background:rgba(0,212,255,.1);color:var(--accent);padding:2px 8px;border-radius:4px;}
.input-field{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:14px 16px;color:var(--text);font-family:'Noto Sans JP',sans-serif;font-size:16px;font-weight:500;outline:none;transition:border-color .2s;-moz-appearance:textfield;}
.input-field::-webkit-outer-spin-button,.input-field::-webkit-inner-spin-button{-webkit-appearance:none;}
.input-field:focus{border-color:var(--accent);box-shadow:var(--glow);}
.input-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.checkbox-group{display:flex;flex-direction:column;gap:10px;}
.checkbox-item{display:flex;align-items:center;gap:12px;padding:14px 16px;background:var(--surface2);border:1px solid var(--border);border-radius:10px;cursor:pointer;transition:all .2s;}
.checkbox-item:hover{border-color:rgba(0,212,255,.3);}
.checkbox-item.checked{border-color:var(--accent3);background:rgba(0,255,136,.05);}
.checkbox-item input{display:none;}
.checkbox-custom{width:20px;height:20px;border:2px solid var(--border);border-radius:5px;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .2s;}
.checkbox-item.checked .checkbox-custom{background:var(--accent3);border-color:var(--accent3);}
.checkbox-check{color:#000;font-size:13px;display:none;font-weight:700;}
.checkbox-item.checked .checkbox-check{display:block;}
.checkbox-text{flex:1;}
.checkbox-title{font-size:14px;font-weight:500;margin-bottom:2px;}
.checkbox-sub{font-size:12px;color:var(--text-muted);}
.calc-btn{width:100%;padding:18px;background:linear-gradient(135deg,var(--accent2),var(--accent));border:none;border-radius:14px;color:#fff;font-family:'Noto Sans JP',sans-serif;font-size:17px;font-weight:700;cursor:pointer;transition:all .25s;letter-spacing:1px;margin-top:8px;}
.calc-btn:hover:not(:disabled){transform:translateY(-2px);box-shadow:0 8px 30px rgba(0,100,255,.4);}
.calc-btn:disabled{opacity:.4;cursor:not-allowed;}
.sep{height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);margin:32px 0;}
#result-section{display:none;animation:fadeIn .5s ease;}
@keyframes fadeIn{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
.result-header{text-align:center;padding:32px;background:var(--surface);border:1px solid rgba(0,255,136,.3);border-radius:16px;margin-bottom:16px;position:relative;overflow:hidden;}
.result-header::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 50% 0%,rgba(0,255,136,.08),transparent 60%);}
.result-tag{display:inline-block;background:rgba(0,255,136,.15);border:1px solid rgba(0,255,136,.4);color:var(--accent3);font-size:11px;letter-spacing:2px;padding:5px 14px;border-radius:20px;margin-bottom:16px;font-family:'Inter',sans-serif;font-weight:600;}
.result-pref{font-size:13px;color:var(--text-muted);margin-bottom:6px;}
.result-amount{font-size:clamp(36px,8vw,60px);font-weight:900;font-family:'Inter',sans-serif;background:linear-gradient(135deg,var(--accent3),var(--accent));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1;margin:12px 0 8px;position:relative;z-index:1;}
.result-amount-label{font-size:14px;color:var(--text-muted);position:relative;z-index:1;}
.cond-badge{display:inline-block;font-size:11px;padding:3px 10px;border-radius:6px;margin:2px 4px;font-weight:600;}
.cond-special{background:rgba(255,200,0,.15);color:#ffc800;border:1px solid rgba(255,200,0,.3);}
.subsidy-name-card{background:linear-gradient(135deg,rgba(0,100,255,.1),rgba(0,212,255,.07));border:1px solid rgba(0,212,255,.3);border-radius:14px;padding:22px 24px;margin-bottom:16px;}
.subsidy-name-label{font-size:11px;letter-spacing:2px;color:var(--accent);font-family:'Inter',sans-serif;font-weight:600;margin-bottom:8px;}
.subsidy-name-title{font-size:17px;font-weight:700;line-height:1.5;margin-bottom:6px;}
.subsidy-name-based{font-size:12px;color:var(--text-muted);}
.detail-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:16px;}
.detail-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:16px;}
.detail-card-label{font-size:11px;color:var(--text-muted);letter-spacing:1px;margin-bottom:8px;font-family:'Inter',sans-serif;}
.detail-card-value{font-size:19px;font-weight:700;font-family:'Inter',sans-serif;color:var(--accent);}
.detail-card-sub{font-size:11px;color:var(--text-muted);margin-top:4px;}
/* Timeline */
.timeline-card{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:24px;margin-bottom:16px;}
.timeline-title{font-size:13px;font-weight:700;color:var(--warn);margin-bottom:20px;}
.tl-item{display:flex;gap:16px;position:relative;}
.tl-item:not(:last-child)::after{content:'';position:absolute;left:15px;top:34px;bottom:0;width:2px;background:linear-gradient(to bottom,var(--border),transparent);z-index:0;}
.tl-dot{width:32px;height:32px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;font-family:'Inter',sans-serif;z-index:1;margin-top:2px;}
.tl-dot.p-open{background:rgba(0,212,255,.2);border:2px solid var(--accent);color:var(--accent);}
.tl-dot.p-entry{background:rgba(255,193,7,.2);border:2px solid var(--warn);color:var(--warn);}
.tl-dot.p-apply{background:rgba(0,255,136,.2);border:2px solid var(--accent3);color:var(--accent3);}
.tl-dot.p-decide{background:rgba(136,136,255,.2);border:2px solid #8888ff;color:#8888ff;}
.tl-dot.p-execute{background:rgba(255,107,53,.2);border:2px solid var(--care);color:var(--care);}
.tl-dot.p-report{background:rgba(150,150,150,.2);border:2px solid #888;color:#aaa;}
.tl-body{padding-bottom:20px;flex:1;}
.tl-date{font-size:12px;font-weight:700;color:var(--warn);font-family:'Inter',sans-serif;margin-bottom:3px;}
.tl-label{font-size:14px;font-weight:600;margin-bottom:3px;}
.tl-desc{font-size:12px;color:var(--text-muted);line-height:1.6;}
.tl-urgent{display:inline-block;font-size:10px;background:rgba(255,82,82,.2);color:#ff7070;border:1px solid rgba(255,82,82,.3);border-radius:4px;padding:1px 6px;margin-left:6px;font-weight:700;}
/* Info */
.info-section{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:20px 24px;margin-bottom:14px;}
.info-section.cond{border-left:3px solid var(--accent3);}
.info-section.items{border-left:3px solid var(--accent);}
.info-section-title{font-size:13px;font-weight:700;margin-bottom:12px;}
.info-section-body{font-size:13px;color:var(--text-muted);line-height:1.7;}
.info-list{list-style:none;display:flex;flex-direction:column;gap:8px;}
.info-list li{font-size:13px;color:var(--text-muted);line-height:1.6;padding-left:18px;position:relative;}
.info-list li::before{content:'▸';position:absolute;left:0;color:var(--accent3);font-size:11px;top:2px;}
.tag-req{display:inline-block;font-size:10px;background:rgba(255,82,82,.15);color:#ff8080;border:1px solid rgba(255,82,82,.3);border-radius:4px;padding:1px 6px;margin-left:6px;font-weight:700;vertical-align:middle;}
.tag-opt{display:inline-block;font-size:10px;background:rgba(0,255,136,.12);color:var(--accent3);border:1px solid rgba(0,255,136,.3);border-radius:4px;padding:1px 6px;margin-left:6px;font-weight:700;vertical-align:middle;}
.notes-card{background:var(--surface);border:1px solid var(--border);border-left:3px solid var(--accent);border-radius:12px;padding:20px 24px;margin-bottom:16px;}
.notes-title{font-size:13px;font-weight:700;color:var(--accent);margin-bottom:12px;}
.notes-list{list-style:none;}
.notes-list li{font-size:13px;color:var(--text-muted);line-height:1.7;padding-left:16px;position:relative;}
.notes-list li::before{content:'›';position:absolute;left:0;color:var(--accent);font-weight:700;}
.notes-window{margin-top:12px;padding-top:12px;border-top:1px solid var(--border);font-size:13px;color:var(--accent);font-weight:500;}
.site-link-btn{display:inline-flex;align-items:center;gap:6px;margin-top:14px;padding:11px 20px;background:linear-gradient(135deg,rgba(0,212,255,.15),rgba(0,100,255,.15));border:1px solid rgba(0,212,255,.45);border-radius:10px;color:var(--accent);font-size:13px;font-weight:700;text-decoration:none;font-family:'Noto Sans JP',sans-serif;transition:all .2s;}
.site-link-btn:hover{background:linear-gradient(135deg,rgba(0,212,255,.25),rgba(0,100,255,.25));box-shadow:0 0 16px rgba(0,212,255,.25);transform:translateY(-1px);}
.site-link-none{margin-top:10px;font-size:12px;color:var(--text-muted);font-style:italic;}
.alert-card{background:rgba(255,107,53,.07);border:1px solid rgba(255,107,53,.3);border-radius:12px;padding:16px 20px;margin-bottom:16px;font-size:13px;color:rgba(255,107,53,.9);line-height:1.7;display:flex;gap:10px;}
.reset-btn{width:100%;padding:14px;background:transparent;border:1px solid var(--border);border-radius:12px;color:var(--text-muted);font-family:'Noto Sans JP',sans-serif;font-size:14px;cursor:pointer;transition:all .2s;margin-top:8px;}
.reset-btn:hover{border-color:var(--accent);color:var(--text);}
@media(max-width:600px){.genre-grid{grid-template-columns:1fr 1fr;}.input-row{grid-template-columns:1fr;}.detail-grid{grid-template-columns:1fr 1fr;}}
</style>
</head>
<body>
<div class="container">
<header>
  <div class="badge">SUBSIDY CALCULATOR 2025</div>
  <h1>見守りカメラ補助金<br>自動算出シート</h1>
  <p class="subtitle">都道府県・施設種別を選択 → 補助金額・名称・申請フロー・期限を自動表示</p>
</header>

<div class="step-card active" id="step1">
  <div class="step-header"><div class="step-num">1</div><div class="step-label">施設・機関の種別を選択</div></div>
  <div class="genre-grid">
    <div class="genre-btn care" id="btn-care" onclick="selectGenre('care')">
      <span class="genre-icon">🏥</span><div class="genre-name">介護施設</div>
      <div class="genre-desc">介護老人福祉施設・老健・グループホーム等の介護事業所</div>
    </div>
    <div class="genre-btn medical" id="btn-medical" onclick="selectGenre('medical')">
      <span class="genre-icon">🏨</span><div class="genre-name">病院・有床診療所</div>
      <div class="genre-desc">ベースアップ評価料届出済の病院・有床診療所</div>
    </div>
  </div>
</div>

<div class="step-card" id="step2">
  <div class="step-header"><div class="step-num">2</div><div class="step-label">都道府県を選択</div></div>
  <div class="pref-search">
    <span class="search-icon">🔍</span>
    <input type="text" id="pref-search" placeholder="都道府県名で検索..." oninput="filterPref(this.value)">
  </div>
  <div id="pref-list"></div>
</div>

<div class="step-card" id="step3">
  <div class="step-header"><div class="step-num">3</div><div class="step-label">導入内容・施設情報を入力</div></div>
  <div id="care-inputs" style="display:none">
    <div class="input-row">
      <div class="input-group">
        <div class="input-label">見守り機器の導入台数 <span class="unit">台</span></div>
        <input type="number" class="input-field" id="camera-count" placeholder="例: 10" min="1">
      </div>
      <div class="input-group">
        <div class="input-label">1台あたりの機器費用 <span class="unit">万円</span></div>
        <input type="number" class="input-field" id="unit-price" placeholder="例: 20" min="1">
      </div>
    </div>
    <div class="input-group">
      <div class="input-label">3点セット導入予定（補助率引き上げ対象）</div>
      <div class="checkbox-group">
        <label class="checkbox-item">
          <input type="checkbox" id="chk-3set" onchange="toggleCheck(this)">
          <div class="checkbox-custom"><span class="checkbox-check">✓</span></div>
          <div class="checkbox-text">
            <div class="checkbox-title">見守りセンサー ＋ インカム ＋ 介護ソフトを同時導入</div>
            <div class="checkbox-sub">3点セット導入で補助率が 3/4 に引き上げられる場合があります</div>
          </div>
        </label>
      </div>
    </div>
  </div>
  <div id="medical-inputs" style="display:none">
    <div class="input-row">
      <div class="input-group">
        <div class="input-label">許可病床数 <span class="unit">床</span></div>
        <input type="number" class="input-field" id="bed-count" placeholder="例: 200" min="1">
      </div>
      <div class="input-group">
        <div class="input-label">導入予定の総費用 <span class="unit">万円</span></div>
        <input type="number" class="input-field" id="medical-cost" placeholder="例: 500" min="1">
      </div>
    </div>
    <div class="input-group">
      <div class="input-label">令和6年度「ベースアップ評価料」の届出状況</div>
      <div class="checkbox-group">
        <label class="checkbox-item">
          <input type="checkbox" id="chk-baseup" onchange="toggleCheck(this)">
          <div class="checkbox-custom"><span class="checkbox-check">✓</span></div>
          <div class="checkbox-text">
            <div class="checkbox-title">2024年4月1日時点でベースアップ評価料を届け出ている</div>
            <div class="checkbox-sub">この届出が補助金申請の前提条件となります</div>
          </div>
        </label>
      </div>
    </div>
  </div>
</div>

<button class="calc-btn" id="calc-btn" onclick="calculate()" disabled>🧮 補助金額・申請フロー・期限を自動算出する</button>
<div class="sep"></div>
<div id="result-section">
  <div id="result-content"></div>
  <button class="reset-btn" onclick="resetAll()">↩ 最初からやり直す</button>
</div>
</div>

<script>
const prefRegions={
  "北海道・東北":["北海道","青森県","岩手県","宮城県","秋田県","山形県","福島県"],
  "関東":["茨城県","栃木県","群馬県","埼玉県","千葉県","東京都","神奈川県"],
  "中部":["新潟県","富山県","石川県","福井県","山梨県","長野県","岐阜県","静岡県","愛知県"],
  "近畿":["三重県","滋賀県","京都府","大阪府","兵庫県","奈良県","和歌山県"],
  "中国":["鳥取県","島根県","岡山県","広島県","山口県"],
  "四国":["徳島県","香川県","愛媛県","高知県"],
  "九州・沖縄":["福岡県","佐賀県","長崎県","熊本県","大分県","宮崎県","鹿児島県","沖縄県"]
};

// 標準フロー生成
function stdFlow(openDate,closeDate,decideDate,execDate,reportDate,openDesc){
  return [
    {p:"open",date:openDate,label:"公募開始",desc:openDesc||"都道府県ウェブサイトで公募要領・申請様式を公開。"},
    {p:"apply",date:closeDate,label:"申請書類提出締切",desc:"交付申請書・事業計画書・見積書等を提出。",urgent:true},
    {p:"decide",date:decideDate,label:"交付決定通知",desc:"採択結果を書面で通知。決定後に機器発注・購入が可能。"},
